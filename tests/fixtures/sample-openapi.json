{
  "openapi": "3.1.0",
  "info": { "title": "Fixture", "version": "0.0.1" },
  "paths": {
    "/v1/things": {
      "get": {
        "tags": ["things"],
        "summary": "List things",
        "operationId": "list_things_v1_things_get",
        "responses": {
          "200": { "description": "ok", "content": { "application/json": { "schema": {} } } }
        }
      },
      "post": {
        "tags": ["things"],
        "summary": "Create thing",
        "operationId": "create_thing_v1_things_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ThingCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "ok", "content": { "application/json": { "schema": {} } } }
        }
      }
    },
    "/v1/things/{thing_id}": {
      "delete": {
        "tags": ["things"],
        "summary": "Delete thing",
        "operationId": "delete_thing_v1_things__thing_id__delete",
        "parameters": [
          {
            "name": "thing_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "ok" }
        }
      }
    },
    "/app/views/index": {
      "get": {
        "tags": ["views"],
        "summary": "Should be skipped",
        "operationId": "view_index_app_views_index_get",
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/healthz": {
      "get": {
        "tags": ["health"],
        "summary": "Health",
        "operationId": "healthz_healthz_get",
        "responses": { "200": { "description": "ok" } }
      }
    }
  },
  "components": {
    "schemas": {
      "ThingCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "kind": {
            "type": "string",
            "enum": ["small", "large"],
            "default": "small"
          },
          "tags": {
            "anyOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "null" }
            ]
          }
        }
      }
    }
  }
}
